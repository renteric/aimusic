[flake8]
max-line-length = 120
max-complexity = 18
select = E,F,W
ignore = E203, E266, E501, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    .mypy_cache,
    .pytest_cache,
    .tox,
    .eggs,
    *.egg,
    .vscode,
    .idea,
    .ropeproject,
    .pytest_cache,
    .mypy_cache,
    .coverage,
    .hypothesis

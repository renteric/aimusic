# ─────────────────────────────────────────────────────────────────────────────
# AI-Music — Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port exposed by the nginx frontend container.
APP_PORT=80

# ── FastAPI backend ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# Secret key for JWT signing — must be a long random string in prod.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT token lifetime in minutes (default 1440 = 24 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root or absolute).
DB_PATH=data/app.db

# ── Default admin account (first-run only) ────────────────────────────────────
# Created automatically if no users exist. Change the password immediately.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Media ─────────────────────────────────────────────────────────────────────
# Output folder for downloaded files (relative to project root or absolute).
MEDIA_DIR=media

# Directory for user markdown documents (relative to project root or absolute).
DOCS_DIR=docs

# How long completed download job logs are kept in memory (seconds).
JOB_MAX_AGE_SECONDS=3600

# ── Transcribe service ────────────────────────────────────────────────────────
# URL of the Whisper transcription service (resolves via Docker service name).
TRANSCRIBE_SERVICE_URL=http://transcribe:9000

# Port the transcription service binds to inside its container.
# Must match the port in TRANSCRIBE_SERVICE_URL.
TRANSCRIBE_PORT=9000

# Directory where Whisper model weights are cached inside the transcribe container.
# The named volume in docker-compose.yml is mounted here for persistence.
WHISPER_CACHE_DIR=/app/.cache/whisper

# ── Separator microservice ────────────────────────────────────────────────────
# Internal URL of the stem extraction microservice (Docker service name).
SEPARATOR_URL=http://separator:8000

# ── LALAL.AI (stem extraction) ────────────────────────────────────────────────
# API key for LALAL.AI cloud stem separation.
# Obtain from: https://www.lalal.ai/api/
# Leave blank to disable LALAL.AI functionality.
MUSEP_LALALAI_API_KEY=

# ── Hugging Face Hub (model hosting) ─────────────────────────────────────────
# API key for Hugging Face Hub to upload and manage models.
# https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_API_KEY=

# ── Anthropic Claude API (AI intelligence layer) ──────────────────────────────
# Required for /api/ai/* endpoints (transcript cleanup, song analysis).
# Obtain from: https://console.anthropic.com/settings/keys
# Leave blank to disable all AI features gracefully.
ANTHROPIC_API_KEY=

# ── Development CORS ─────────────────────────────────────────────────────────
# Comma-separated origins allowed in development (Vite dev server).
# Leave empty in production — nginx handles everything on the same origin.
CORS_ORIGINS=http://localhost:5173
